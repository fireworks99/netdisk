<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="com.example.netdisk.mapper.SysPermissionMapper">

    <resultMap id="SysPermissionResultMap" type="com.example.netdisk.entity.SysPermission">
        <id property="id" column="id"/>
        <result property="permissionCode" column="permission_code"/>
        <result property="permissionName" column="permission_name"/>
        <result property="type" column="type"/>
        <result property="parentId" column="parent_id"/>
        <result property="path" column="path"/>
        <result property="method" column="method"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!-- 查询全部权限 -->
    <select id="findAll" resultMap="SysPermissionResultMap">
        SELECT id, permission_code, permission_name, type, parent_id, path, method, create_time
        FROM sys_permission
        ORDER BY id
    </select>

    <!-- 根据ID查询 -->
    <select id="findById" resultMap="SysPermissionResultMap">
        SELECT id, permission_code, permission_name, type, parent_id, path, method, create_time
        FROM sys_permission
        WHERE id = #{id}
    </select>

    <!-- 新增权限 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_permission (permission_code, permission_name, type, parent_id, path, method, create_time)
        VALUES (#{permissionCode}, #{permissionName}, #{type}, #{parentId}, #{[path}, #{method}, now())
    </insert>

    <!-- 删除权限 -->
    <delete id="deleteById">
        DELETE FROM sys_permission WHERE id = #{id}
    </delete>

</mapper>